# XRPL network: testnet | mainnet
VITE_NETWORK=testnet

# Set to "true" to re-enable local seed-based signing in the UI for fast testnet
# development. Leave unset/false anywhere the app is publicly reachable — this
# is the only thing standing between a visitor and your seed input.
VITE_DEV_SEED_MODE=false

# Ports (defaults shown — only needed if you want to change them)
PORT=5173
API_PORT=8787

# Xaman (XUMM) API credentials — server-side only, from https://apps.xumm.dev
# Never expose these to the frontend / commit them.
XUMM_APIKEY=
XUMM_APISECRET=
