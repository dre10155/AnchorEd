{
  "name": "anchored",
  "description": "AnchorEd — tamper-proof academic credentials anchored on the XRP Ledger. Issue and verify diplomas in seconds.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "Andreas Mendes",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.4",
    "qrcode": "^1.5.4",
    "qrcode-reader-vue3": "^4.1.0",
    "vue": "^3.4.38",
    "vue-router": "^4.2.5",
    "xrpl": "^4.5.0",
    "xumm-sdk": "^1.11.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.1.3",
    "autoprefixer": "^10.4.17",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.4"
  }
}
